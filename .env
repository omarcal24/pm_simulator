# .env.example (copy to .env)

## Backend
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
# Use SQLite for local dev (default). For PostgreSQL:
# DATABASE_URL=postgres://user:pass@localhost:5432/pms
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

## LLM Grading (OpenAI)
OPENAI_API_KEY=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
# Model used for grading decisions (default: gpt-4o)
OPENAI_GRADER_MODEL=gpt-4o
# Temperature for grading calls (default: 0.2)
OPENAI_GRADER_TEMPERATURE=0.2

## Frontend (Vite proxies /api to backend when using npm run dev)
# No env needed for local dev; API calls go to same origin