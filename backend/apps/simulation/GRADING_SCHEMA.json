{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "PM Simulator LLM Grading Output",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "rubric_version",
        "overall_score",
        "universal_score",
        "dimension_scores",
        "role_scores",
        "gates",
        "strengths",
        "improvements",
        "red_flags",
        "confidence"
    ],
    "properties": {
        "rubric_version": {
            "type": "string"
        },
        "overall_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 5
        },
        "universal_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 5
        },
        "dimension_scores": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "key",
                    "score",
                    "reason"
                ],
                "properties": {
                    "key": {
                        "type": "string",
                        "enum": [
                            "problem_framing",
                            "tradeoffs",
                            "evidence_assumptions",
                            "execution_realism",
                            "metrics_success"
                        ]
                    },
                    "score": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 5
                    },
                    "reason": {
                        "type": "string",
                        "minLength": 1
                    }
                }
            }
        },
        "role_scores": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "role",
                    "score",
                    "reason"
                ],
                "properties": {
                    "role": {
                        "type": "string",
                        "enum": [
                            "engineering",
                            "design",
                            "data",
                            "sales_cs",
                            "exec"
                        ]
                    },
                    "score": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 5
                    },
                    "reason": {
                        "type": "string",
                        "minLength": 1
                    }
                }
            }
        },
        "gates": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "has_clear_recommendation",
                "mentions_constraints",
                "mentions_success_metrics",
                "mentions_risks_and_mitigation",
                "compares_alternatives"
            ],
            "properties": {
                "has_clear_recommendation": {
                    "type": "boolean"
                },
                "mentions_constraints": {
                    "type": "boolean"
                },
                "mentions_success_metrics": {
                    "type": "boolean"
                },
                "mentions_risks_and_mitigation": {
                    "type": "boolean"
                },
                "compares_alternatives": {
                    "type": "boolean"
                }
            }
        },
        "strengths": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "improvements": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "red_flags": {
            "type": "array",
            "maxItems": 8,
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
        }
    }
}